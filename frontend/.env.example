# Frontend Environment Variables Example
# Copy this file to .env and fill in your actual values

# Backend URL (deployed app URL)
REACT_APP_BACKEND_URL=https://orientation-paths.preview.emergentagent.com

# WebSocket configuration
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false

# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here
